# Google Earth Engine Configuration
# Get credentials: https://console.cloud.google.com → IAM → Service Accounts
GEE_PROJECT=your-gcp-project-id
GEE_SERVICE_ACCOUNT_KEY=/path/to/your-service-account-key.json
GEE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com

# Server Configuration
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Environment: "development" (default) or "production".
# In production, JWT_SECRET MUST be set or the app refuses to start.
ENV=development

# Authentication: REQUIRED in production.
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# Database (optional, defaults to SQLite)
# DATABASE_URL=sqlite+aiosqlite:///./desert_tracker.db
